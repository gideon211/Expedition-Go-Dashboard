# TravioAfrica Admin Dashboard - Environment Variables Template
# Copy this file to .env.development for local development
# Copy this file to .env.production for production builds

# =============================================================================
# API Configuration
# =============================================================================

# Backend API Base URL
VITE_API_BASE_URL=https://expedition-go-backend-v2.onrender.com/api

# API Request Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# API Retry Attempts
VITE_API_RETRY_ATTEMPTS=3

# =============================================================================
# Authentication Configuration
# =============================================================================

# Auth Provider (firebase | auth0 | custom)
VITE_AUTH_PROVIDER=firebase

# Firebase Configuration (if using Firebase)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Auth.js-compatible backend configuration
VITE_AUTH_API_BASE_URL=https://expedition-go-backend-v2.onrender.com/api

# Token Refresh Interval (milliseconds) - refresh 5 minutes before expiry
VITE_TOKEN_REFRESH_INTERVAL=300000

# Session Timeout (milliseconds) - 30 minutes
VITE_SESSION_TIMEOUT=1800000

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/Disable Features
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_REAL_TIME_UPDATES=false
VITE_FEATURE_ADVANCED_FILTERS=true
VITE_FEATURE_EXPORT_DATA=true
VITE_FEATURE_BULK_ACTIONS=true

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Sentry DSN (Error Tracking)
VITE_SENTRY_DSN=

# Sentry Environment
VITE_SENTRY_ENVIRONMENT=development

# Enable Debug Logging
VITE_DEBUG_MODE=true

# Log Level (debug | info | warn | error)
VITE_LOG_LEVEL=debug

# =============================================================================
# Analytics
# =============================================================================

# Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID=

# Enable Analytics
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# Application Configuration
# =============================================================================

# Application Name
VITE_APP_NAME=TravioAfrica Admin Dashboard

# Application Version
VITE_APP_VERSION=1.0.0

# Application Environment (development | staging | production)
VITE_APP_ENV=development

# Base URL (for routing)
VITE_BASE_URL=/

# =============================================================================
# Performance Configuration
# =============================================================================

# Enable Service Worker
VITE_ENABLE_SERVICE_WORKER=false

# Cache Strategy (network-first | cache-first | stale-while-revalidate)
VITE_CACHE_STRATEGY=network-first

# =============================================================================
# Upload Configuration
# =============================================================================

# Max File Upload Size (bytes) - 5MB
VITE_MAX_FILE_SIZE=5242880

# Allowed File Types (comma-separated)
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# =============================================================================
# Pagination Configuration
# =============================================================================

# Default Page Size
VITE_DEFAULT_PAGE_SIZE=25

# Max Page Size
VITE_MAX_PAGE_SIZE=100

# =============================================================================
# Map Configuration (if using maps)
# =============================================================================

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox Access Token
VITE_MAPBOX_ACCESS_TOKEN=

# =============================================================================
# Third-Party Integrations
# =============================================================================

# Stripe Public Key (for payments)
VITE_STRIPE_PUBLIC_KEY=

# Intercom App ID (for customer support)
VITE_INTERCOM_APP_ID=

# =============================================================================
# Development Tools
# =============================================================================

# Enable React Query Devtools
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Enable Redux Devtools
VITE_ENABLE_REDUX_DEVTOOLS=true

# Mock API Responses (for development)
VITE_MOCK_API=false
